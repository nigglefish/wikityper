javascript:(async()=>{const DEFAULT_SPEED=200,START_DELAY=5,SPEED_KEY="wikityper.speed";const d=document,w=window;if(w.__wikiTextOnly){w.__wikiTextOnly.cleanup();return}const nodes=[...d.body.children].map(n=>[n,n.style.display]);nodes.forEach(([n])=>n.style.display="none");let spans=[],target=[],startAt=0,pos=0,red=-1,dangers=new Set(),started=false,waiting=false,waitAt=-1,redTimer=0;const clearTimer=()=>{if(redTimer)clearTimeout(redTimer);redTimer=0};const clamp=(n,a,b)=>Math.max(a,Math.min(n,b));const box=d.createElement("main");box.id="wiki-text-only-view";box.tabIndex=-1;box.style.cssText="display:block!important;max-width:75ch;margin:2rem auto;padding:0 2rem 4rem;font:18px/1.6 system-ui,-apple-system,Segoe UI,sans-serif;color:#111;background:#fff;outline:0";box.textContent="Loading%20text-only%20Wikipedia%20article%E2%80%A6";const%20panel=d.createElement("aside");panel.id="wiki-text-only-panel";const%20panelBase="display:grid!important;grid-template-columns:2em%208em%202em%202em%203em;gap:0;align-items:center;justify-items:right;position:fixed;right:0;top:0.5em;z-index:2147483647;width:15em;padding:.3em;border-radius:1em%200%200%201em;background:#000;color:#fff;box-shadow:0%20.55em%201.7em%20rgba(0,0,0,.24);font:14px/1.35%20system-ui,-apple-system,Segoe%20UI,sans-serif;backdrop-filter:blur(.7em);overflow:hidden;transition:transform%20.22s%20ease,opacity%20.22s%20ease";const%20panelHidden=panelBase+";transform:translateX(12.8em);opacity:.45";const%20panelShown=panelBase+";transform:translateX(0.8em);opacity:1";panel.style.cssText=panelHidden;const%20cleanup=()=>{clearTimer();w.__wikiTextOnly.keyHandler&&d.removeEventListener("keydown",w.__wikiTextOnly.keyHandler,true);box.remove();panel.remove();nodes.forEach(([n,s])=>n.style.display=s);delete%20w.__wikiTextOnly;};let%20open=false;const%20collapse=()=>{open=false;panel.style.cssText=panelHidden};const%20controls=d.createElement("div");controls.style.cssText="display:contents";const%20input=d.createElement("input");input.type="text";input.inputMode="numeric";input.pattern="[0-9]*";input.placeholder="speed...";input.value=localStorage.getItem(SPEED_KEY)||String(DEFAULT_SPEED);input.style.cssText="width:90%;box-sizing:border-box;padding:.3em;border:0;border-radius:.6em;font-size:1.1em;background:#fff;color:#000;outline:none";const%20saveSpeed=()=>{input.value=[...input.value].filter(c=>c>='0'&&c<='9').join('');localStorage.setItem(SPEED_KEY,input.value||String(DEFAULT_SPEED));};input.oninput=saveSpeed;input.onkeydown=e=>{if(e.key==='Enter'){e.preventDefault();saveSpeed();collapse();input.blur();box.focus()}};const%20gear=d.createElement("button");gear.type="button";gear.setAttribute("aria-label","Options");gear.textContent="%E2%9B%AD";gear.style.cssText="position:relative;top:-.04em;font-size:2em;cursor:pointer;user-select:none;color:#fff;background:transparent;border:0;padding:0;line-height:1";gear.onclick=e=>{e.stopPropagation();if(open)collapse()};const%20reset=d.createElement("button");reset.type="button";reset.setAttribute("aria-label","Reset");reset.textContent="%E2%86%BB";reset.style.cssText="position:relative;top:-.04em;font-size:1.8em;cursor:pointer;user-select:none;color:#fff;background:transparent;border:0;padding:0;line-height:1";const%20close=d.createElement("button");close.type="button";close.setAttribute("aria-label","Restore%20page");close.textContent="%C3%97";close.style.cssText="position:relative;top:-.08em;font-size:2em;cursor:pointer;user-select:none;color:#fff;background:transparent;border:0;padding:0;line-height:1";close.onclick=cleanup;controls.append(gear,input,reset,close);panel.onmouseenter=()=>{open=true;panel.style.cssText=panelShown};panel.onmouseleave=collapse;panel.append(controls);d.body.append(box,panel);w.__wikiTextOnly={box,panel,nodes,cleanup};try{const%20title=(w.mw&&mw.config&&mw.config.get("wgPageName"))||decodeURIComponent(location.pathname.replace(/^\/wiki\//,"").replace(/_/g,"%20"));const%20api=location.origin+"/w/api.php?action=query&format=json&prop=extracts&explaintext=1&exsectionformat=wiki&redirects=1&titles="+encodeURIComponent(title);const%20r=await%20fetch(api);const%20j=await%20r.json();const%20page=Object.values(j.query.pages)[0];const%20blocks=[{level:1,text:page.title||title}];let%20para=[];const%20clean=t=>t.replace(/\s+/g,"%20").trim();const%20flush=()=>{const%20t=clean(para.join("%20"));if(t)blocks.push({level:0,text:t});para=[]};(page.extract||"No%20plain-text%20extract%20found.").split(/\n/).forEach(line=>{const%20m=line.match(/^(={1,6})\s*(.*?)\s*\1$/);if(m){flush();blocks.push({level:Math.min(m[1].length+1,6),text:m[2]})}else%20if(line.trim()==="")flush();else%20para.push(line);});flush();const%20GREEN_BG="rgba(46,204,113,.35)",GREEN_FG="#096b2e",RED_BG="rgba(231,76,60,.32)",RED_FG="#7b1111",ERR_BG="#e00",ERR_FG="#fff",NL=String.fromCharCode(10);const%20clearMark=s=>{if(s._mark){s._mark.remove();s._mark=null}};const%20clearSpan=i=>{const%20s=spans[i];if(!s)return;s.textContent=s.dataset.ch;clearMark(s);s.style.background="";s.style.color=""};const%20clearAllMarks=()=>spans.forEach((_,i)=>clearSpan(i));const%20addMark=(s,bg,fg)=>{if(!s._mark){s._mark=d.createElement("span");s._mark.textContent="\u00a0";const%20p=spans[+s.dataset.i-1];if(p&&p.parentNode)p.parentNode.insertBefore(s._mark,p.nextSibling);else%20s.parentNode.insertBefore(s._mark,s);}s._mark.style.cssText="background:"+bg+";color:"+fg;};const%20paintSpan=i=>{const%20s=spans[i];if(!s)return;clearSpan(i);if(dangers.has(i)&&i>=startAt){if(target[i]===NL)addMark(s,ERR_BG,ERR_FG);else{s.style.background=ERR_BG;s.style.color=ERR_FG}}else%20if(i>=startAt&&i<=red){if(target[i]!==NL){s.style.background=RED_BG;s.style.color=RED_FG}}else%20if(i>=startAt&&i<pos){s.style.background=GREEN_BG;s.style.color=GREEN_FG;}};const%20paintRange=(a,b)=>{for(let%20i=Math.max(0,a);i<=Math.min(b,target.length-1);i++)paintSpan(i)};const%20put=(parent,ch)=>{const%20s=d.createElement("span");s.textContent=ch;s.dataset.ch=ch;s.dataset.i=spans.length;parent.appendChild(s);spans.push(s);target.push(ch);};const%20enter=()=>put(box,NL);const%20addBlock=(b,i)=>{const%20el=d.createElement(b.level?"h"+b.level:"p");el.style.cssText=b.level===1?"font-size:2.3rem;line-height:1.15;margin:0%200%201rem":b.level===2?"font-size:1.7rem;line-height:1.25;margin:2rem%200%20.75rem;border-bottom:1px%20solid%20#ddd;padding-bottom:.25rem":b.level===3?"font-size:1.35rem;line-height:1.3;margin:1.5rem%200%20.5rem":b.level?"font-size:1.1rem;line-height:1.35;margin:1.25rem%200%20.4rem":"margin:0%200%201em;white-space:normal";clean(b.text).split("").forEach(ch=>put(el,ch));box.appendChild(el);if(i<blocks.length-1)enter();};box.innerHTML="";blocks.forEach(addBlock);const%20unit=()=>60000/Math.max(1,parseInt(input.value,10)||DEFAULT_SPEED);const%20schedule=n=>{clearTimer();redTimer=setTimeout(tick,n*unit())};const%20catchPlayer=()=>{const%20i=Math.max(startAt,Math.min(pos-1,target.length-1));dangers.add(i);red=i;waiting=true;waitAt=i;clearTimer();paintSpan(i);};const%20advanceChaser=()=>{if(waiting||pos<=startAt||pos>target.length)return;if(red<pos-1){red++;paintSpan(red);if(red>=pos-1)catchPlayer();}};const%20tick=()=>{redTimer=0;advanceChaser();if(!waiting&&red<pos-1)schedule(1);};const%20start=()=>{if(!started){started=true;schedule(START_DELAY)}};const%20resetGame=(at=0,scroll=false)=>{clearTimer();clearAllMarks();startAt=clamp(at,0,target.length);pos=startAt;red=startAt-1;started=false;waiting=false;waitAt=-1;dangers.clear();if(scroll)scrollTo({top:0,behavior:"smooth"});};const%20advancePlayer=(run)=>{const%20old=pos;if(run){pos+=run;paintRange(old,pos-1)}else{pos++;paintSpan(old)}if(red>=pos){const%20oldRed=red;red=pos-1;paintRange(red+1,oldRed)}keepUp();if(waiting){waiting=false;waitAt=-1;schedule(START_DELAY)}else%20start();};const%20keepUp=()=>{const%20s=spans[pos];if(!s)return;const%20r=s.getBoundingClientRect();if(r.bottom>innerHeight*.9)scrollBy({top:r.bottom-innerHeight*.72,behavior:"smooth"});};const%20typable=ch=>ch&&ch.length===1&&ch.charCodeAt(0)>=32&&ch.charCodeAt(0)<=126;const%20ws=ch=>ch!==''&&String(ch).trim()==='';const%20got=e=>e.key==='Enter'?NL:e.key==='Tab'?String.fromCharCode(9):e.key==='%20'||e.key==='Spacebar'?'%20':e.key.length===1?e.key:null;const%20wsRun=i=>{let%20j=i;while(ws(target[j]))j++;return%20j-i};const%20matches=(exp,g,run)=>run?exp==='%20'?g==='%20':exp===NL?g===NL:ws(g):(!typable(exp)&&g)||g===exp;const%20keyHandler=e=>{if(d.activeElement===input||e.metaKey||e.ctrlKey||e.altKey)return;const%20exp=target[pos],g=got(e);if(exp==null||!g)return;e.preventDefault();const%20run=ws(exp)?wsRun(pos):0;if(matches(exp,g,run))advancePlayer(run);else%20advanceChaser();};reset.onclick=e=>{e.stopPropagation();resetGame(0,true)};box.onclick=e=>{const%20s=e.target.closest&&e.target.closest("span[data-i]");if(s&&box.contains(s))resetGame(+s.dataset.i)};w.__wikiTextOnly.keyHandler=keyHandler;d.addEventListener("keydown",keyHandler,true);resetGame(0);}catch(e){box.textContent="Could%20not%20load%20plain-text%20version:%20"+e.message}})()